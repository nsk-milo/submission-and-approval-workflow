# PostgreSQL connection string used by Prisma.
# The compose file publishes Postgres on host port 5434 (to avoid clashing with
# a stock 5432 Postgres). Inside Docker the backend talks to host "postgres:5432".
DATABASE_URL="postgresql://pacra:pacra@localhost:5434/pacra?schema=public"

# Secret used to sign JWT access tokens
JWT_SECRET="change-me-in-production"

# Access token lifetime
JWT_EXPIRES_IN="1d"

# API port
PORT=4000

# Comma separated list of allowed CORS origins for the frontend
CORS_ORIGIN="http://localhost:3000"
